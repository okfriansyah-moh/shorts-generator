{
  "_comment": "Copy this file to meta_credentials.json and fill in your values.",
  "_setup": [
    "1. Go to https://developers.facebook.com and create a Meta app (Business type).",
    "2. Add 'Instagram Graph API' and 'Pages API' products.",
    "3. Connect your Instagram Business/Creator account and your Facebook Page.",
    "4. Generate a Page Access Token via the Graph API Explorer:",
    "   https://developers.facebook.com/tools/explorer/",
    "   Permissions needed: pages_manage_posts, instagram_basic,",
    "   instagram_content_publish, pages_read_engagement",
    "5. Exchange for a long-lived token (60-day expiry, auto-renewable):",
    "   GET /oauth/access_token?grant_type=fb_exchange_token&...",
    "6. Find your Instagram user ID:",
    "   GET /{page-id}?fields=instagram_business_account&access_token=...",
    "7. Fill in the values below and rename to meta_credentials.json.",
    "8. Forward port 8080 (or your chosen meta.serve_port) on your router to this machine.",
    "   Instagram upload works by starting a temporary HTTP server on your public IP.",
    "   No external hosting needed — just port forwarding."
  ],
  "page_access_token": "YOUR_LONG_LIVED_PAGE_ACCESS_TOKEN",
  "instagram_user_id": "YOUR_INSTAGRAM_BUSINESS_USER_ID",
  "facebook_page_id": "YOUR_FACEBOOK_PAGE_ID"
}
