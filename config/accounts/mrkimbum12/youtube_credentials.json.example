{
  "_comment": "Copy this file to youtube_credentials.json and fill in your values.",
  "_setup": [
    "1. Go to https://console.cloud.google.com and create a project.",
    "2. Enable the YouTube Data API v3.",
    "3. Create OAuth 2.0 credentials (Desktop app type).",
    "4. Download the client_secret JSON, extract client_id and client_secret.",
    "5. Run the OAuth consent flow once to obtain refresh_token.",
    "6. Fill in the values below and rename to youtube_credentials.json."
  ],
  "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
  "client_secret": "YOUR_GOOGLE_CLIENT_SECRET",
  "refresh_token": "YOUR_YOUTUBE_REFRESH_TOKEN"
}
