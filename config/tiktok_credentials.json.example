{
  "_comment": "Copy this file to tiktok_credentials.json and fill in your values.",
  "_setup": [
    "1. Go to https://developers.tiktok.com and create an app.",
    "2. Add the 'Content Posting API' product and request approval.",
    "3. Complete the OAuth2 flow once to get your initial refresh_token.",
    "   Use client_key + client_secret with scope: video.publish",
    "4. Paste the values below and rename this file to tiktok_credentials.json."
  ],
  "client_key": "YOUR_TIKTOK_CLIENT_KEY",
  "client_secret": "YOUR_TIKTOK_CLIENT_SECRET",
  "refresh_token": "YOUR_TIKTOK_REFRESH_TOKEN"
}
