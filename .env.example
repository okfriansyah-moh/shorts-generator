# Shorts Factory — Environment Variables
# Copy this file to .env and fill in your values.
# Note: the app does NOT auto-load .env — export these in your shell or crontab.
# For cron, prefix each variable on the crontab line, or source a file with `source /path/to/.env`.

# ── Telegram notifications ─────────────────────────────────────────────────
# Bot token from @BotFather. Chat ID of the group/channel to notify.
SF_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SF_TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Anthropic AI metadata (optional) ──────────────────────────────────────
# Only needed if ai_metadata.enabled=true in config.yaml.
# By default, metadata is generated by Cowork Claude (no API key needed).
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Config overrides (optional) ───────────────────────────────────────────
# These override the corresponding values in config/config.yaml.
# SF_OUTPUT_DIR=output
# SF_TEMP_DIR=output/temp
# SF_DATABASE=output/shorts_factory.db
# SF_TRANSCRIPTION_MODEL=small
# SF_TRANSCRIPTION_LANGUAGE=en
# SF_FFMPEG_TIMEOUT=300
# SF_GPU_ENABLED=false
# SF_GPU_ENCODER=h264_nvenc
